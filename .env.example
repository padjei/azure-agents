# Copy this file to `.env` and fill in your real key.
# `.env` is git-ignored and must NEVER be committed.

# Your Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-real-key-here

# Optional: override the Claude model used by the agent.
# Examples: claude-sonnet-4-6 (default), claude-opus-4-8
# CLAUDE_MODEL=claude-sonnet-4-6
