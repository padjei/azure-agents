# Copy this file to `.env` and fill in what you need.
# `.env` is git-ignored and must NEVER be committed.
#
# By default the agents use your Claude SUBSCRIPTION via OAuth — no key needed.
# Just run `ant auth login` once (install: https://platform.claude.com/docs/en/api/sdks/cli).
# Everything below is OPTIONAL and only for overriding that default.

# --- Option A: use an Anthropic API key instead of your subscription ---------
# If set, this overrides subscription OAuth.
# ANTHROPIC_API_KEY=sk-ant-your-real-key-here

# --- Option B: supply a pre-minted OAuth Bearer token -----------------------
# Usually unnecessary — the agents mint one from your `ant auth login` profile.
# Handy in containers/CI: `eval "$(ant auth print-credentials --env)"`.
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# --- Optional: override the Claude model used by the agents ------------------
# Examples: claude-sonnet-4-6 (default), claude-opus-4-8
# CLAUDE_MODEL=claude-sonnet-4-6
